# VoxFlow — Environment Configuration
# Copy this file to .env and fill in your values.

# LLM Provider (gemini or openai)
LLM_PROVIDER=gemini

# Google Gemini API Key (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenAI API Key (alternative)
OPENAI_API_KEY=

# ── Vapi AI (Voice) ──
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# ── Qdrant Cloud (Vector Retrieval) ──
QDRANT_URL=your_url_here
QDRANT_API_KEY=your_key_here
QDRANT_COLLECTION=voxflow-kb

# Debug mode default (true/false)
DEBUG_MODE=false
