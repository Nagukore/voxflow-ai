{
  "name": "voxflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:clean && concurrently \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:clean": "kill-port 3001 5173 5174",
    "dev:frontend": "vite",
    "dev:backend": "nodemon --watch server --ext js --exec \"node server/index.js\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@qdrant/js-client-rest": "^1.17.0",
    "@vapi-ai/web": "^2.5.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.14",
    "vite": "^5.4.0"
  }
}
